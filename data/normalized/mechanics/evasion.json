                                      },
                     "Conflicts":  {
                                       "text":  "Cannot Evade and similar hit-force states resolve in conflict handling and win over standard Evasion checks.",
                                       "type":  "Official Rule",
                                       "source":  "https://www.poewiki.net/wiki/Evasion"
                                   },
                     "Exceptions":  {
                                        "text":  "Area attack checks for AoE can still rely on target hit rules as part of their own attack resolution path.",
                                        "type":  "Official Rule",
                                        "source":  "https://www.poewiki.net/wiki/Evasion"
                                    },
                     "Hidden Rules":  {
                                          "text":  "Evasion is mostly target-agnostic in source docs and must be interpreted through attack-type specific hit paths.",
                                          "type":  "Official Rule",
                                          "source":  "https://www.poewiki.net/wiki/Evasion"
                                      },
                     "Developer Notes":  {
                                             "text":  "Keep Evasion as a separate hit gate state from Dodge/Block/Spell mechanics to avoid cross-system conflation.",
                                             "type":  "Official Rule",
                                             "source":  "https://www.poewiki.net/wiki/Evasion"
                                         },
                     "Historical Changes":  {
                                                "text":  "Evasion tuning and UI presentation updates occur in balance patches; no merged timeline entered in this pass.",
