{
    "id":  "evasion",
    "term":  "Evasion",
    "status":  "research_pass",
    "classification":  "Official Rule",
    "source":  "https://www.poewiki.net/wiki/Evasion",
    "sections":  {
                     "Definition":  {
                                        "text":  "Evasion is a defensive property that can cause an incoming attack hit check to fail.",
                                        "type":  "Official Rule",
                                        "source":  "https://www.poewiki.net/wiki/Evasion"
                                    },
                     "Purpose":  {
                                     "text":  "Provide probabilistic mitigation for attacks by reducing successful hit probability.",
                                     "type":  "Official Rule",
                                     "source":  "https://www.poewiki.net/wiki/Evasion"
                                 },
                     "Core Rules":  {
                                        "text":  "Evasion is resolved against Accuracy in attack hit checks; spells do not use this gate.",
                                        "type":  "Official Rule",
                                        "source":  "https://www.poewiki.net/wiki/Evasion"
                                    },
                     "Internal Rules":  {
                                            "text":  "Evasion is a target property and applies when attack hit resolution is running; it can be bypassed by Cannot Evade, cannot be interpreted as damage reduction, and does not guarantee fixed mitigation.",
                                            "type":  "Official Rule",
                                            "source":  "https://www.poewiki.net/wiki/Evasion"
                                        },
                     "Calculation Order":  {
                                               "text":  "1) attacker hit source is formed 2) if attack type, perform Accuracy vs Evasion resolution 3) apply min/max bounds and override rules 4) decide hit or miss.",
                                               "type":  "Official Rule",
                                               "source":  "https://www.poewiki.net/wiki/Evasion"
                                           },
                     "Priority Rules":  {
                                            "text":  "Override effects (for example Cannot Evade) supersede normal miss chance from Evasion checks.",
                                            "type":  "Official Rule",
                                            "source":  "https://www.poewiki.net/wiki/Evasion"
                                        },
                     "Preconditions":  {
                                           "text":  "Incoming event must be an attack-based hit check; attack speed and attack source traits are evaluated separately.",
                                           "type":  "Official Rule",
                                           "source":  "https://www.poewiki.net/wiki/Evasion"
                                       },
                     "Postconditions":  {
                                            "text":  "If hit is missed through Evasion, no hit payload is applied and related Hit/Post-Hit mechanics do not run.",
                                            "type":  "Official Rule",
                                            "source":  "https://www.poewiki.net/wiki/Evasion"
                                        },
                     "Limitations":  {
                                         "text":  "Minimum 5% hit chance floor and non-attack scopes mean Evasion cannot affect every combat layer equally.",
                                         "type":  "Official Rule",
                                         "source":  "https://www.poewiki.net/wiki/Evasion"
                                     },
                     "Caps":  {
                                  "text":  "A lower-hit bound and upper-hit bound exist through general hit logic; exact bounds are defined by source hit framework and may be overridden by hit-force effects.",
                                  "type":  "Official Rule",
                                  "source":  "https://www.poewiki.net/wiki/Evasion"
                              },
                     "Formula":  {
                                     "text":  "No single canonical standalone Evasion formula is stored in this pass; source-specific formula for each hit mode is loaded from patch data.",
                                     "type":  "Official Rule",
                                     "source":  "https://www.poewiki.net/wiki/Evasion"
                                 },
                     "Keywords":  {
                                      "text":  [
                                                   "Evasion",
