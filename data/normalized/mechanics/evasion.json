                     "Examples":  {
                                      "text":  [
                                                   "An attack can miss even with high Accuracy when Evasion is high and no override is active.",
                                                   "A 100% hit-force source bypasses this gate."
                                               ],
                                      "type":  "Official Rule",
                                      "source":  "https://www.poewiki.net/wiki/Evasion"
                                  },
                     "Common Misconceptions":  {
                                                   "text":  [
