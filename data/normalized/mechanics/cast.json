{
    "id":  "cast",
    "term":  "Cast",
    "status":  "research_pass",
    "classification":  "Official Rule",
    "source":  "https://www.poewiki.net/wiki/Spell",
    "sections":  {
                     "Definition":  {
                                        "text":  "Cast is the timed action that performs spell delivery after cast start and cast completion.",
                                        "type":  "Official Rule",
                                        "source":  "https://www.poewiki.net/wiki/Spell"
                                    },
                     "Purpose":  {
                                     "text":  "Define non-attack spell delivery through cast timing and spell delivery tags.",
                                     "type":  "Official Rule",
                                     "source":  "https://www.poewiki.net/wiki/Spell"
                                 },
                     "Core Rules":  {
                                        "text":  "Cast actions are delivery actions for spells and are distinct from attack-based delivery actions such as weapon attacks.",
                                        "type":  "Official Rule",
                                        "source":  "https://www.poewiki.net/wiki/Spell"
                                    },
                     "Internal Rules":  {
                                            "text":  "Cast Speed modifies Cast Time through derived casts-per-second conversion used by skill timing.",
                                            "type":  "Official Rule",
                                            "source":  "https://www.poewiki.net/wiki/Cast_speed"
                                        },
                     "Calculation Order":  {
                                               "text":  "1) cast action starts, 2) cast time runs and modified time is computed from cast speed, 3) skill effect starts, 4) hit/DoT/event effects queue and resolve.",
                                               "type":  "Official Rule",
                                               "source":  "https://www.poewiki.net/wiki/Cast_time"
                                           },
                     "Priority Rules":  {
                                            "text":  "Specific cast-time exceptions can override base timing or spell-cast interaction assumptions.",
                                            "type":  "Official Rule",
                                            "source":  "https://www.poewiki.net/wiki/Cast_time"
                                        },
                     "Preconditions":  {
                                           "text":  "The acting entity must use a skill path that is tagged as Spell and is eligible for casting.",
                                           "type":  "Official Rule",
                                           "source":  "https://www.poewiki.net/wiki/Spell"
                                       },
                     "Postconditions":  {
                                            "text":  "Cast delivery is completed and the spell effect enters normal hit/effect resolution.",
                                            "type":  "Official Rule",
                                            "source":  "https://www.poewiki.net/wiki/Spell"
                                        },
                     "Limitations":  {
                                         "text":  "Cast Speed only applies where timing is derived from cast action, not where instant or non-cast pathways are explicitly defined.",
                                         "type":  "Official Rule",
                                         "source":  "https://www.poewiki.net/wiki/Cast_speed"
                                     },
                     "Caps":  {
                                  "text":  "No universal cast speed cap listed at mechanic level; cap behavior is local to source modifiers and systems.",
                                  "type":  "Official Rule",
                                  "source":  "https://www.poewiki.net/wiki/Cast_speed"
                              },
                     "Formula":  {
                                     "text":  "Cast Speed = 1 / Cast Time. If cast speed is modified by +50%, effective casts per second increase by the same modifier factor.",
                                     "type":  "Official Rule",
                                     "source":  "https://www.poewiki.net/wiki/Cast_speed"
                                 },
                     "Keywords":  {
                                      "text":  [
                                                   "Cast",
                                                   "Cast Speed",
                                                   "Cast Time",
                                                   "Spell",
                                                   "Instant"
                                               ],
