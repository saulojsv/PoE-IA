                                                            "source":  "https://www.poewiki.net/wiki/Spell"
                                                        }
                                                    ],
                                           "type":  "Official Rule"
                                       },
                     "Examples":  {
                                      "text":  [
                                                   "A bow spell cast uses Cast Speed and Cast Time for action timing.",
                                                   "A triggered curse cast follows trigger scheduling before resolving its spell effect."
                                               ],
                                      "type":  "Official Rule",
                                      "source":  "https://www.poewiki.net/wiki/Spell"
                                  },
                     "Common Misconceptions":  {
