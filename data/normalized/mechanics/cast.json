                                                       "skill cast timer state"
                                                   ],
                                          "type":  "Official Rule",
                                          "source":  "https://www.poewiki.net/wiki/Cast_speed"
                                      },
                     "Conflicts":  {
                                       "text":  "Attack-tagged components do not use cast action unless explicitly cast-based by source text.",
                                       "type":  "Official Rule",
                                       "source":  "https://www.poewiki.net/wiki/Spell"
                                   },
                     "Exceptions":  {
                                        "text":  "Some triggered paths can launch multiple spells in one action while preserving cast timing rules per trigger logic.",
                                        "type":  "Official Rule",
                                        "source":  "https://www.poewiki.net/wiki/Spell"
                                    },
                     "Hidden Rules":  {
                                          "text":  "Cast timing is often represented through several term variants (cast time, cast speed, cast speed modifier) in mechanics text.",
                                          "type":  "Official Rule",
                                          "source":  "https://www.poewiki.net/wiki/Cast_speed"
                                      },
                     "Developer Notes":  {
                                             "text":  "In storage, keep Cast as a spell-delivery action and normalize Use/Trigger branches by explicit source tags.",
                                             "type":  "Official Rule",
                                             "source":  "https://www.poewiki.net/wiki/Spell"
                                         },
                     "Historical Changes":  {
                                                "text":  "No explicit historical rewrite for Cast label is present in this pass; only historical patch updates captured for dependent systems.",
                                                "type":  "Historical Behavior",
                                                "source":  "https://www.poewiki.net/wiki/Spell"
                                            },
                     "Patch History":  {
                                           "text":  [
                                                        {
