{
    "id":  "nearby",
    "term":  "Nearby",
    "status":  "research_pass",
    "classification":  "Observed Behavior",
    "source":  "https://www.poewiki.net/wiki/Distance",
    "sections":  {
                     "Definition":  {
                                        "text":  "Nearby is not a keyword; it denotes an effect applying in a circular area around a source object or entity.",
                                        "type":  "Official Rule",
                                        "source":  "https://www.poewiki.net/wiki/Distance"
                                    },
                     "Purpose":  {
                                     "text":  "Used to express area targeting scope without committing to a fixed, universally visible radius value.",
                                     "type":  "Observed Behavior",
                                     "source":  "https://www.poewiki.net/wiki/Distance"
                                 },
                     "Core Rules":  {
                                        "text":  "Nearby applies as an area relation to the source of the effect and may be used by skills, passives, and modifiers.",
                                        "type":  "Observed Behavior",
                                        "source":  "https://www.poewiki.net/wiki/Distance"
                                    },
                     "Internal Rules":  {
                                            "text":  "Actual radius is defined per source text/value and is not guaranteed to be the same between all Nearby usages.",
                                            "type":  "Observed Behavior",
                                            "source":  "https://www.poewiki.net/wiki/Distance"
                                        },
                     "Calculation Order":  {
                                               "text":  "Area collection occurs during the effect-resolution step, after source selection and before effect application.",
                                               "type":  "Observed Behavior",
                                               "source":  "poe.wiki"
                                           },
                     "Priority Rules":  {
                                            "text":  "Specific radius values on the source entry override any generic Nearby interpretation.",
                                            "type":  "Observed Behavior",
                                            "source":  "https://www.poewiki.net/wiki/Distance"
                                        },
                     "Preconditions":  {
                                           "text":  "Requires an effect that is textually scoped as nearby and a valid source entity for circular check.",
                                           "type":  "Observed Behavior",
                                           "source":  "https://www.poewiki.net/wiki/Distance"
                                       },
                     "Postconditions":  {
                                            "text":  "Only entities in the resolved nearby area are eligible for the effect.",
                                            "type":  "Observed Behavior",
                                            "source":  "https://www.poewiki.net/wiki/Distance"
                                        },
                     "Limitations":  {
                                         "text":  "Nearby is not the same as a fixed keyword constant; UI does not always expose radius values.",
                                         "type":  "Observed Behavior",
                                         "source":  "https://www.poewiki.net/wiki/Distance"
                                     },
                     "Caps":  {
                                  "text":  "No global nearby cap is defined by the term itself.",
                                  "type":  "Observed Behavior",
                                  "source":  "https://www.poewiki.net/wiki/Distance"
                              },
                     "Formula":  {
                                     "text":  "No standalone formula for Nearby; radius is resolved per source definition.",
                                     "type":  "Observed Behavior",
                                     "source":  "https://www.poewiki.net/wiki/Distance"
                                 },
