                                   },
                     "Exceptions":  {
                                        "text":  "Searches for nearby entities do not include non-blocking objects or untargetable/invulnerable bosses in scripted phases.",
                                        "type":  "Observed Behavior",
                                        "source":  "https://www.poewiki.net/wiki/Distance"
                                    },
                     "Hidden Rules":  {
                                          "text":  "Nearby is explicitly documented as not a keyword in official-style terminology text and may not receive uniform radius patches.",
                                          "type":  "Observed Behavior",
                                          "source":  "https://www.poewiki.net/wiki/Distance"
                                      },
                     "Developer Notes":  {
                                             "text":  "Record per-skill/per-source radius values; avoid converting Nearby into a universal radius constant.",
                                             "type":  "Observed Behavior",
                                             "source":  "https://www.poewiki.net/wiki/Distance"
                                         },
                     "Historical Changes":  {
                                                "text":  "No discrete patch event recorded for Nearby as a global keyword in this pass.",
