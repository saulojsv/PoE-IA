    "classification":  "Official Rule",
    "source":  "https://www.poewiki.net/wiki/Recently",
    "sections":  {
                     "Definition":  {
                                        "text":  "Recently is a capitalized keyword that means the past four seconds.",
                                        "type":  "Official Rule",
                                        "source":  "https://www.poewiki.net/wiki/Recently"
                                    },
                     "Purpose":  {
                                     "text":  "Provide a standardized short time-window condition across skills, passives, and items.",
                                     "type":  "Official Rule",
                                     "source":  "https://www.poewiki.net/wiki/Keyword"
                                 },
                     "Core Rules":  {
                                        "text":  "A condition with Recently is true when the tracked event occurred within 4 seconds.",
                                        "type":  "Official Rule",
                                        "source":  "https://www.poewiki.net/wiki/Recently"
                                    },
                     "Internal Rules":  {
                                            "text":  "Recently is keyword-grade logic, not natural-language interpretation of \u0027recently\u0027.",
                                            "type":  "Official Rule",
                                            "source":  "https://www.poewiki.net/wiki/Keyword"
                                        },
                     "Calculation Order":  {
                                               "text":  "Check event timestamp against current time and compare against 4s threshold before applying Recently-bound modifiers.",
                                               "type":  "Official Rule",
                                               "source":  "https://www.poewiki.net/wiki/Recently"
                                           },
                     "Priority Rules":  {
                                            "text":  "Keyword capitalization is required in modifier text to trigger the strict 4-second definition.",
                                            "type":  "Official Rule",
                                            "source":  "https://www.poewiki.net/wiki/Keyword"
                                        },
                     "Preconditions":  {
                                           "text":  "Action or state event timestamp must be available for the subject being checked.",
                                           "type":  "Official Rule",
                                           "source":  "https://www.poewiki.net/wiki/Recently"
                                       },
                     "Postconditions":  {
                                            "text":  "The effect or branch guarded by Recently is enabled only if the event is within 4 seconds.",
                                            "type":  "Official Rule",
                                            "source":  "https://www.poewiki.net/wiki/Recently"
                                        },
                     "Limitations":  {
                                         "text":  "Window is fixed at 4 seconds for the keyword definition.",
                                         "type":  "Official Rule",
                                         "source":  "https://www.poewiki.net/wiki/Recently"
                                     },
                     "Caps":  {
                                  "text":  "No numeric cap beyond the fixed 4-second window.",
                                  "type":  "Official Rule",
                                  "source":  "https://www.poewiki.net/wiki/Recently"
                              },
                     "Formula":  {
                                     "text":  "Condition = now - event_time \u003c= 4s",
                                     "type":  "Official Rule",
                                     "source":  "https://www.poewiki.net/wiki/Recently"
                                 },
