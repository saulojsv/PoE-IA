{
    "id":  "debuff",
    "term":  "Debuff",
    "status":  "research_pass",
    "classification":  "Official Rule",
    "source":  "https://www.poewiki.net/wiki/Buff",
    "sections":  {
                     "Definition":  {
                                        "text":  "A Debuff is a primarily detrimental effect applied to a target, structurally paired with Buff and sharing effect-attachment mechanics.",
                                        "type":  "Official Rule",
                                        "source":  "https://www.poewiki.net/wiki/Buff"
                                    },
                     "Purpose":  {
                                     "text":  "Represent negative modifier states so target statistics, damage handling, or resource interaction can be reduced.",
                                     "type":  "Official Rule",
                                     "source":  "https://www.poewiki.net/wiki/Buff"
                                 },
                     "Core Rules":  {
                                        "text":  "A Debuff is an effect entry attached to an entity and applies negative modifiers as defined by the source mechanic.",
                                        "type":  "Official Rule",
                                        "source":  "https://www.poewiki.net/wiki/Buff"
                                    },
                     "Internal Rules":  {
                                            "text":  "Debuff stacking, duration, and replacement behaviour are implemented per mechanic unless that mechanic explicitly allows stacking.",
                                            "type":  "Official Rule",
                                            "source":  "https://www.poewiki.net/wiki/Buff"
                                        },
                     "Calculation Order":  {
                                               "text":  "1) application attempt 2) stack/override resolution 3) modifier application 4) duration/tick progression 5) expiration removal.",
                                               "type":  "Official Rule",
                                               "source":  "https://www.poewiki.net/wiki/Buff"
                                           },
                     "Priority Rules":  {
                                            "text":  "By default multiple identical Debuff instances do not stack; strongest instance remains unless the mechanic explicitly allows stacking.",
                                            "type":  "Official Rule",
                                            "source":  "https://www.poewiki.net/wiki/Buff"
                                        },
                     "Preconditions":  {
                                           "text":  "Source mechanic must be valid to apply the Debuff and the target must satisfy source applicability constraints.",
                                           "type":  "Official Rule",
                                           "source":  "https://www.poewiki.net/wiki/Buff"
                                       },
                     "Postconditions":  {
                                            "text":  "Target receives negative modifier state and keeps it for effective Debuff duration or until overridden/removed.",
                                            "type":  "Official Rule",
                                            "source":  "https://www.poewiki.net/wiki/Buff"
                                        },
                     "Limitations":  {
                                         "text":  "Some effect families are blocked from applying to enemy Debuffs; see mechanic-specific exceptions.",
                                         "type":  "Official Rule",
                                         "source":  "https://www.poewiki.net/wiki/Buff"
                                     },
                     "Caps":  {
                                  "text":  "Stacking and duration caps are mechanic-specific; generic Debuff model defaults to non-stacking identical states.",
                                  "type":  "Official Rule",
                                  "source":  "https://www.poewiki.net/wiki/Buff"
                              },
                     "Formula":  {
                                     "text":  "No universal formula applies to all Debuffs; each Debuff defines its own magnitude, duration, and scaling.",
                                     "type":  "Official Rule",
                                     "source":  "https://www.poewiki.net/wiki/Buff"
                                 },
                     "Keywords":  {
                                      "text":  [
                                                   "Debuff",
                                                   "negative modifier",
                                                   "duration",
                                                   "stacking exception",
                                                   "Buff"
                                               ],
                                      "type":  "Official Rule",
                                      "source":  "https://www.poewiki.net/wiki/Buff"
                                  },
