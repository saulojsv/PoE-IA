                                           },
                     "Dependencies":  {
                                          "text":  [
                                                       "Attachment system",
                                                       "Effect duration model",
                                                       "mechanic-specific stacking tags"
                                                   ],
                                          "type":  "Official Rule",
                                          "source":  "https://www.poewiki.net/wiki/Buff"
                                      },
                     "Conflicts":  {
                                       "text":  "Enemy Debuff interaction with auras and effect amplification changes by patch; apply mechanic version history when relevant.",
                                       "type":  "Historical Behavior",
                                       "source":  "https://www.poewiki.net/wiki/Buff"
                                   },
                     "Exceptions":  {
                                        "text":  "Specific Debuffs can define layering, stacking, or immunity interactions that override generic Debuff defaults.",
                                        "type":  "Official Rule",
                                        "source":  "https://www.poewiki.net/wiki/Buff"
                                    },
                     "Hidden Rules":  {
                                          "text":  "UI flags for buff/debuff are not equivalent to all mechanical constraints.",
                                          "type":  "Official Rule",
                                          "source":  "https://www.poewiki.net/wiki/Buff"
                                      },
                     "Developer Notes":  {
                                             "text":  "Treat Debuff as shared state machinery with mechanic-local overrides; do not use one global formula.",
                                             "type":  "Official Rule",
                                             "source":  "https://www.poewiki.net/wiki/Buff"
                                         },
                     "Historical Changes":  {
                                                "text":  "Buff/Debuff framework fixes changed inversion and aura interaction behavior in patch history.",
                                                "type":  "Historical Behavior",
                                                "source":  "https://www.poewiki.net/wiki/Buff"
                                            },
                     "Patch History":  {
                                           "text":  [
                                                        {
                                                            "version":  "3.28.0e",
                                                            "note":  "Buff effects transitioned through combat areas for temporary minions, Rage, Fortify, charges, and shrines.",
                                                            "type":  "Official Rule",
                                                            "source":  "https://www.poewiki.net/wiki/Buff"
                                                        },
                                                        {
                                                            "version":  "3.16.2b",
                                                            "note":  "Most buff effect modifiers could no longer invert buff effects.",
                                                            "type":  "Official Rule",
                                                            "source":  "https://www.poewiki.net/wiki/Buff"
                                                        },
                                                        {
                                                            "version":  "3.10.1c",
                                                            "note":  "Increased Effect of Auras on You modifiers stopped applying to enemy Debuff auras.",
                                                            "type":  "Official Rule",
                                                            "source":  "https://www.poewiki.net/wiki/Buff"
                                                        }
                                                    ],
                                           "type":  "Official Rule"
                                       },
                     "Examples":  {
                                      "text":  [
                                                   "Withered applies as a Debuff-like negative state with explicit stacking and effect rules.",
                                                   "Mark and Hex are Debuff-adjacent systems with curse-limit constraints."
                                               ],
                                      "type":  "Official Rule",
                                      "source":  "https://www.poewiki.net/wiki/Buff"
                                  },
                     "Common Misconceptions":  {
                                                   "text":  [
                                                                "Debuff is not interchangeable with Ailment in all calculations.",
                                                                "Debuff icon absence does not mean no negative effect."
                                                            ],
                                                   "type":  "Official Rule",
                                                   "source":  "https://www.poewiki.net/wiki/Buff"
                                               },
