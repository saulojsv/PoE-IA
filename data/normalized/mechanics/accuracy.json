{
    "id":  "accuracy",
    "term":  "Accuracy",
    "status":  "research_pass",
    "classification":  "Official Rule",
    "source":  "https://www.poewiki.net/wiki/Accuracy",
    "sections":  {
                     "Definition":  {
                                        "text":  "Accuracy is a property of attack hits used with target evasion to calculate an attack\u0027s chance to hit.",
                                        "type":  "Official Rule",
                                        "source":  "https://www.poewiki.net/wiki/Accuracy"
                                    },
                     "Purpose":  {
                                     "text":  "Determine hit success for attacks and gate secondary critical-strike checks for non-spell attacks.",
                                     "type":  "Official Rule",
                                     "source":  "https://www.poewiki.net/wiki/Accuracy"
                                 },
                     "Core Rules":  {
                                        "text":  "Attack hit chance is based on attacker Accuracy and defender Evasion using the PoE formula, then clamped to a minimum 5% and maximum 100%. Spells do not use Accuracy because they cannot be evaded.",
                                        "type":  "Official Rule",
                                        "source":  "https://www.poewiki.net/wiki/Accuracy"
                                    },
                     "Internal Rules":  {
                                            "text":  "Accuracy also runs a second check for critical-strike resolution after hit resolution for attack criticals; failed check converts a would-be critical to a regular hit.",
                                            "type":  "Official Rule",
                                            "source":  "https://www.poewiki.net/wiki/Accuracy"
                                        },
                     "Calculation Order":  {
                                               "text":  "1) compute uncapped chance to hit from Accuracy versus Evasion 2) clamp to [0.05,1] chance range 3) apply modifiers that force hit behavior (Always Hit/Cannot Evade) 4) resolve hit outcome 5) if a non-spell hit is eligible for critical strike, perform secondary accuracy check.",
                                               "type":  "Official Rule",
                                               "source":  "https://www.poewiki.net/wiki/Accuracy"
                                           },
                     "Priority Rules":  {
                                            "text":  "Effects that set hit chance to 100% for attacker/defender interactions override normal Accuracy vs Evasion checks.",
                                            "type":  "Official Rule",
                                            "source":  "https://www.poewiki.net/wiki/Accuracy"
                                        },
                     "Preconditions":  {
                                           "text":  "Only attack hits are evaluated; spell hits are excluded because spells do not benefit from Accuracy.",
                                           "type":  "Official Rule",
                                           "source":  "https://www.poewiki.net/wiki/Accuracy"
                                       },
                     "Postconditions":  {
                                            "text":  "The engine resolves hit/miss, then applies hit-based consequences such as critical strike qualification and related modifiers.",
                                            "type":  "Official Rule",
                                            "source":  "https://www.poewiki.net/wiki/Accuracy"
                                        },
                     "Limitations":  {
                                         "text":  "A minimum 5% miss chance remains unless overridden by cannot-be-evaded effects; chance does not exceed 100% for normal calculations.",
                                         "type":  "Official Rule",
                                         "source":  "https://www.poewiki.net/wiki/Accuracy"
                                     },
                     "Caps":  {
                                  "text":  "Minimum hit chance is 5%; maximum is 100%.",
                                  "type":  "Official Rule",
                                  "source":  "https://www.poewiki.net/wiki/Accuracy"
                              },
                     "Formula":  {
                                     "text":  "Uncapped chance to hit = 1.25*Accuracy/(Accuracy+(Evasion/5)^0.9) . Chance to hit = min(max(Uncapped,0.05),1).",
                                     "type":  "Official Rule",
                                     "source":  "https://www.poewiki.net/wiki/Accuracy"
                                 },
