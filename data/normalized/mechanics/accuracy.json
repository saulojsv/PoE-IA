                     "Examples":  {
                                      "text":  [
                                                   "A source with 10% increased chance to hit converts to higher Accuracy checks and higher final hit chance within the clamped range.",
                                                   "Attack hits can still miss via evasion when hit chance is below 100%."
                                               ],
                                      "type":  "Official Rule",
                                      "source":  "https://www.poewiki.net/wiki/Accuracy"
                                  },
                     "Common Misconceptions":  {
                                                   "text":  [
                                                                "Accuracy is not a hit-by-hit guarantee; it is checked against evasion and bounded by minimum/maximum values.",
                                                                "Critical strike chance alone does not guarantee critical hit; attack accuracy second-check can downgrade it."
                                                            ],
                                                   "type":  "Official Rule",
                                                   "source":  "https://www.poewiki.net/wiki/Accuracy"
