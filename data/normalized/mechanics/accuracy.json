                     "Conflicts":  {
                                       "text":  "Critical strike chance from spells bypasses this Accuracy-based secondary check.",
                                       "type":  "Official Rule",
                                       "source":  "https://www.poewiki.net/wiki/Accuracy"
                                   },
                     "Exceptions":  {
                                        "text":  "Area-of-effect attack hits still use Accuracy and may be evaded even if target is visibly inside the area.",
                                        "type":  "Official Rule",
                                        "source":  "https://www.poewiki.net/wiki/Accuracy"
                                    },
                     "Hidden Rules":  {
                                          "text":  "Conditional accuracy modifiers on a skill do not apply to generic skill references not tied to hit-specific context.",
                                          "type":  "Official Rule",
                                          "source":  "https://www.poewiki.net/wiki/Accuracy"
                                      },
                     "Developer Notes":  {
                                             "text":  "Use separate states for attack hit validation and damage formula; avoid inferring Accuracy from spell hit behavior.",
